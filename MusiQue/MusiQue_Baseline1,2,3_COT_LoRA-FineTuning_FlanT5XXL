irst hop: use the original question\n","            query = question\n","        else:\n","            # Later hops: use bridge entity + key question terms\n","            # This focuses BM25 on the bridge entity\n","            query = bridge_answers[-1] + \" \" + question\n","            # Give bridge entity more weight by repeating it\n","            query = bridge_answers[-1] + \" \" + bridge_answers[-1] + \" \" + question\n","\n","        query_tokens = simple_tokenize(query)\n","        scores = bm25.get_scores(query_tokens)\n","\n","        ranked = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)\n","        new_indices = []\n","        for idx in ranked:\n","            if idx not in all_retrieved_indices:\n","                new_indices.append(idx)\n","                if len(new_indices) >= k_per_hop:\n","                    break\n","\n","        if not new_indices:\n","            break\n","\n","        all_retrieved_indices.update(new_indices)\n","\n","        # Answer using all retrieved so far\n","        current_context = \"\\n\\n\".join(para_texts[idx] for idx in sorted(all_retrieved_indices))\n","        intermediate_answer = run_model(build_qa_prompt(question, current_context))\n","        bridge_answers.append(intermediate_answer)\n","\n","        hop_details.append({\n","            \"hop\": hop + 1,\n","            \"query_start\": query[:60],\n","            \"new_paras\": len(new_indices),\n","            \"total_paras\": len(all_retrieved_indices),\n","            \"answer\": intermediate_answer,\n","        })\n","\n","        if hop > 0 and intermediate_answer == bridge_answers[-2]:\n","            break\n","\n","    # Final: CoT over all retrieved\n","    final_context = \"\\n\\n\".join(para_texts[idx] for idx in sorted(all_retrieved_indices))\n","    raw = run_model(build_cot_prompt_v3(question, final_context), max_tokens=256)\n","    final_pred = extract_answer_v3(raw)\n","\n","    supporting_retrieved = sum(\n","      