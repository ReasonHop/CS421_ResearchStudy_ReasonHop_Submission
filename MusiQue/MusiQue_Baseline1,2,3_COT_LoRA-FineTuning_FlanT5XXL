graphs:\n","        if p.get(\"is_supporting\"):\n","            title = p.get(\"title\", \"\").strip()\n","            text = p.get(\"paragraph_text\", \"\").strip()\n","            # Take first sentence as the key supporting fact\n","            first_sent = text.split(\". \")[0].strip()\n","            if not first_sent.endswith(\".\"):\n","                first_sent += \".\"\n","            supporting_facts.append(f\"[{title}] {first_sent}\")\n","\n","    evidence_str = \" | \".join(supporting_facts)\n","    answer = ex[\"answer\"]\n","\n","    input_text = f\"Identify the supporting facts and answer the question.\\n\\nQuestion: {question}\\n\\nContext:\\n{context}\\n\\nSupporting facts and answer:\"\n","    target_text = f\"Evidence: {evidence_str}\\nAnswer: {answer}\"\n","\n","    return input_text, target_text\n","\n","class MuSiQEMultitaskDataset(Dataset):\n","    def __init__(self, file_path, tokenizer, max_input_len=1024, max_target_len=256, max_examples=None):\n","        self.tokenizer = tokenizer\n","        self.max_input_len = max_input_len\n","        self.max_target_len = max_target_len\n","        self.examples = []\n","\n","        with open(file_path, \"r\") as f:\n","            for i, line in enumerate(f):\n","                if max_examples and i >= max_examples:\n","                    break\n","                ex = json.loads(line)\n","                if not ex.get(\"answerable\", True):\n","                    continue\n","                input_text, target_text = build_multitask_training_example(ex)\n","                self.examples.append((input_text, target_text))\n","\n","    def __len__(self):\n","        return len(self.examples)\n","\n","    def __getitem__(self, idx):\n","        input_text, target_text = self.examples[idx]\n","\n","        inputs = self.tokenizer(\n","            input_text,\n","            max_length=self.max_input_len,\n","            truncation=True,\n","            padding=\"max_length\",\n","            return_tensors=\"pt\"\n","        )\n","\n","        targets = self.tokenizer(\n","            target_text,\n","            max_length=self.max_target_len,\n","            truncation=True,\n","            padding=\"max_length\",\n","            return_tensors=\"pt\"\n","        )\n","\n","        # Replace padding token ids with -100 so they're ignored in loss\n","        labels = targets[\"input_ids\"].squeeze()\n","        labels[labels == self.tokenizer.pad_token_id] = -100\n","\n","        return {\n","            \"input_ids\": inputs[\"input_ids\"].squeeze(),\n","            \"attention_mask\": inputs[\"attention_mask\"].squeeze(),\n","            \"labels\": labels,\n","        }\n","\n","# Build dataset — use max_input_len=1024 to keep memory manageable\n","# (full 20 paragraphs won't fit, but we get ~5-8 paragraphs worth)\n","train_dataset = MuSiQEMultitaskDataset(\n","    TRAIN_FILE, tokenizer,\n","    max_input_len=1024,\n","    max_target_len=256,\n","    max_examples=5000  # start with 5K for speed, scale up if it works\n",")\n","\n","print(f\"Training examples: {len(train_dataset)}\")\n","\n","# Inspect a few examples\n","for i in [0, 1, 2]:\n","    inp, tgt = train_dataset.examples[i]\n","    print(f\"\\n{'='*80}\")\n","    print(f\"Example {i+1}\")\n","    print(f\"INPUT (first 300 chars): {inp[:300]}\")\n","    print(f\"TARGET: {tgt[:300]}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ysDSEagGKvMh","executionInfo":{"status":"ok","timestamp":1776055779130,"user_tz":300,"elapsed":2182,"user":{"displayName":"Siddhi Dabholkar","userId":"11668982913240243302"}},"outputId":"aadd70e9-b2ad-437c-f4db-713525ba225a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Training examples: 5000\n","\n","================================================================================\n","Example 1\n","INPUT (first 300 chars): Identify the supporting facts and answer the question.\n","\n","Question: What is the country where Nissedal is located named after?\n","\n","Context:\n","Title: Milton F. Pavlic\n","Milton F. Pavlic (1909–1942) was a United States Navy officer killed in action during World War II for whom a U.S. Navy high-speed transport \n","TARGET: Evidence: [Norway] Norway has a total area of and a population of 5,312,300 (as of August 2018). | [Tveitsund] Tveitsund is a village in Nissedal municipality, Norway.\n","Answer: north\n","\n","================================================================================\n","Example 2\n","INPUT (first 300 chars): Identify the supporting facts and answer the question.\n","\n","Question: What is the highest point in the country where Bugabula is found?\n","\n","Context:\n","Title: Bugabula\n","Bugabula is one of the five traditional principalities of the kingdom of Busoga in Uganda. It is located in the Kamuli District.\n","\n","Title: Iran\n","\n","TARGET: Evidence: [Bugabula] Bugabula is one of the five traditional principalities of the kingdom of Busoga in Uganda. | [Green-breasted pitta] It is found in Cameroon, Central African Republic, Republic of the Congo, DRC, Gabon, and Uganda.\n","Answer: 1,400 metres\n","\n","================================================================================\n","Example 3\n","INPUT (first 300 chars): Identify the supporting facts and answer the question.\n","\n","Question: Who from the state with the Routzahn-Miller Farmstead signed the declaration of independence?\n","\n","Context:\n","Title: United States Declaration of Independence\n","The Declaration became official when Congress voted for it on July 4; signatures \n","TARGET: Evidence: [Routzahn-Miller Farmstead] The Routzahn-Miller Farmstead is a historic home and farm complex located at Middletown, Frederick County, Maryland, United States. | [Charles Carroll of Carrollton] Charles Carroll (September 19, 1737 -- November 14, 1832), known as Charles Carroll of Carrollto\n"]}]},{"cell_type":"code","source":["# Method 5, Step 4 (v3): Train on oracle context — model learns the task format\n","\n","import gc, torch, time\n","from torch.utils.data import DataLoader, Dataset\n","\n","# Cleanup\n","if 'peft_model' in dir():\n","    del peft_model\n","if 'optimizer' in dir():\n","    del optimizer\n","gc.collect()\n","torch.cuda.empty_cache()\n","\n","# Fresh LoRA\n","from peft import LoraConfig, get_peft_model, TaskType\n","\n","lora_config = LoraConfig(\n","    task_type=TaskType.SEQ_2_SEQ_LM,\n","    r=8, lora_alpha=16, lora_dropout=0.05,\n","    target_modules=[\"q\", \"v\"],\n",")\n","model.enable_input_require_grads()\n","model.gradient_checkpointing_enable()\n","peft_model = get_peft_model(model, lora_config)\n","\n","# New dataset: oracle supporting paragraphs as context\n","class MuSiQEOracleDataset(Dataset):\n","    def __init__(self, file_path, tokenizer, max_input_len=512, max_target_len=128, max_examples=None):\n","        self.tokenizer = tokenizer\n","        self.max_input_len = max_input_len\n","        self.max_target_len = max_target_len\n","        self.examples = []\n","\n","        with open(file_path, \"r\") as f:\n","            for i, line in enumerate(f):\n","                if max_examples and i >= max_examples:\n","                    break\n","                ex = json.loads(line)\n","                if not ex.get(\"answerable\", True):\n","                    continue\n","\n","                question = ex[\"question\"]\n","                answer = ex[\"answer\"]\n","\n","                # Oracle context: only supporting paragraphs\n","                supporting = [p for p in ex[\"paragraphs\"] if p.get(\"is_supporting\")]\n","                context = \"\\n\\n\".join(paragraph_to_text(p) for p in supporting)\n","\n","                # Evidence: first sentence from each supporting paragraph\n","                evidence_parts = []\n","                for p in supporting:\n","                    title = p.get(\"title\", \"\").strip()\n","                    text = p.get(\"paragraph_text\", \"\").strip()\n","                    first_sent = text.split(\". \")[0].strip()\n","                    if not first_sent.endswith(\".\"):\n","                        first_sent += \".\"\n","                    evidence_parts.append(f\"[{title}] {first_sent}\")\n","\n","                evidence_str = \" | \".join(evidence_parts)\n","\n","                input_text = (f\"Identify the supporting facts and answer the question.\\n\\n\"\n","                             f\"Question: {question}\\n\\nContext:\\n{context}\\n\\n\"\n","                             f\"Supporting facts and answer:\")\n","                target_text = f\"Evidence: {evidence_str}\\nAnswer: {answer}\"\n","\n","                self.examples.append((input_text, target_text))\n","\n","    def __len__(self):\n","        return len(self.examples)\n","\n","    def __getitem__(self, idx):\n","        input_text, target_text = self.examples[idx]\n","        inputs = self.tokenizer(input_text, max_length=self.max_input_len,\n","                               truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n","        targets = self.tokenizer(target_text, max_length=self.max_target_len,\n","                                truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n","        labels = targets[\"input_ids\"].squeeze()\n","        labels[labels == self.tokenizer.pad_token_id] = -100\n","        return {\n","            \"input_ids\": inputs[\"input_ids\"].squeeze(),\n","            \"attention_mask\": inputs[\"attention_mask\"].squeeze(),\n","            \"labels\": labels,\n","        }\n","\n","train_dataset_oracle = MuSiQEOracleDataset(\n","    TRAIN_FILE, tokenizer,\n","    max_input_len=512, max_target_len=128,\n","    max_examples=5000\n",")\n","\n","# Verify: check that context fits\n","sample_inp, sample_tgt = train_dataset_oracle.examples[0]\n","sample_tokens = tokenizer(sample_inp, return_tensors=\"pt\")\n","print(f\"Training examples: {len(train_dataset_oracle)}\")\n","print(f\"Sample input tokens: {sample_tokens['input_ids'].shape[1]}\")\n","print(f\"Sample target: {sample_tgt[:200]}\")\n","print()\n","\n","# Train\n","BATCH_SIZE = 1\n","GRAD_ACCUM_STEPS = 16\n","EPOCHS = 3\n","LR = 5e-5\n","\n","train_loader = DataLoader(train_dataset_oracle, batch_size=BATCH_SIZE, shuffle=True)\n","optimizer = torch.optim.AdamW(peft_model.parameters(), lr=LR, weight_decay=0.01, eps=1e-4)\n","\n","total_steps = len(train_loader) * EPOCHS // GRAD_ACCUM_STEPS\n","warmup_steps = total_steps // 10\n","\n","def get_lr(step):\n","    if step < warmup_steps:\n","        return max(0.01, step / warmup_steps)\n","    return max(0.1, 1.0 - (step - warmup_steps) / (total_steps - warmup_steps))\n","\n","peft_model.train()\n","global_step = 0\n","best_loss = float(\"inf\")\n","\n","print(f\"Training config:\")\n","print(f\"  Context: oracle supporting paragraphs\")\n","print(f\"  Input/Target len: 512/128\")\n","print(f\"  Effective batch: {BATCH_SIZE * GRAD_ACCUM_STEPS}\")\n","print(f\"  Total steps: {total_steps}\")\n","print()\n","\n","for epoch in range(EPOCHS):\n","    epoch_loss = 0\n","    epoch_steps = 0\n","    nan_count = 0\n","    start = time.time()\n","    optimizer.zero_grad()\n","\n","    for batch_idx, batch in enumerate(train_loader):\n","        input_ids = batch[\"input_ids\"].to(device)\n","        attention_mask = batch[\"attention_mask\"].to(device)\n","        labels = batch[\"labels\"].to(device)\n","\n","        try:\n","            outputs = peft_model(input_ids=input_ids, attention_mask=attention_mask, labels=labels)\n","            loss = outputs.loss / GRAD_ACCUM_STEPS\n","\n","            if torch.isnan(loss):\n","                nan_count += 1\n","                continue\n","\n","            loss.backward()\n","            epoch_loss += outputs.loss.item()\n","            epoch_steps += 1\n","        except RuntimeError as e:\n","            if \"out of memory\" in str(e):\n","                torch.cuda.empty_cache()\n","                nan_count += 1\n","                continue\n","            raise\n","\n","        if (batch_idx + 1) % GRAD_ACCUM_STEPS == 0:\n","            lr_scale = get_lr(global_step)\n","            for pg in optimizer.param_groups:\n","                pg[\"lr\"] = LR * lr_scale\n","            torch.nn.utils.clip_grad_norm_(peft_model.parameters(), 0.5)\n","            optimizer.step()\n","            optimizer.zero_grad()\n","            global_step += 1\n","\n","        if (batch_idx + 1) % 500 == 0:\n","            avg_loss = epoch_loss / max(epoch_steps, 1)\n","            elapsed = time.time() - start\n","            print(f\"  Epoch {epoch+1} [{batch_idx+1}/{len(train_loader)}] \"\n","                  f\"loss={avg_loss:.4f} nan={nan_count} time={elapsed:.0f}s\")\n","\n","    avg_loss = epoch_loss / max(epoch_steps, 1)\n","    elapsed = time.time() - start\n","    print(f\"\\nEpoch {epoch+1}/{EPOCHS} — loss: {avg_loss:.4f} nan: {nan_count} time: {elapsed:.0f}s\")\n","\n","    if avg_loss < best_loss and avg_loss > 0:\n","        best_loss = avg_loss\n","        peft_model.save_pretrained(\"/content/drive/MyDrive/421-Project/lora_method5_best\")\n","        print(f\"  Saved best model (loss={best_loss:.4f})\")\n","    print()\n","\n","print(f\"Training complete! Best loss: {best_loss:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":626},"id":"lM4KMXd3LHVL","executionInfo":{"status":"error","timestamp":1776060328844,"user_tz":300,"elapsed":1469750,"user":{"displayName":"Siddhi Dabholkar","userId":"11668982913240243302"}},"outputId":"769d9187-52b9-4c9d-8022-77a922fa8f89"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Training examples: 5000\n","Sample input tokens: 274\n","Sample target: Evidence: [Norway] Norway has a total area of and a population of 5,312,300 (as of August 2018). | [Tveitsund] Tveitsund is a village in Nissedal municipality, Norway.\n","Answer: