ell_type":"code","source":["# B3b Step 1: Sentence-level evidence selection — helpers + 10 example test   (NEW)\n","\n","import re\n","from rank_bm25 import BM25Okapi\n","\n","def split_paragraph_to_sentences(paragraph):\n","    \"\"\"Split a paragraph dict into individual sentences with metadata.\"\"\"\n","    title = paragraph.get(\"title\", \"\").strip()\n","    text = paragraph.get(\"paragraph_text\", \"\").strip()\n","    is_supporting = paragraph.get(\"is_supporting\", False)\n","\n","    # Split on sentence boundaries\n","    raw_sents = re.split(r'(?<=[.!?])\\s+', text)\n","    sentences = []\n","    for s in raw_sents:\n","        s = s.strip()\n","        if len(s) > 10:  # skip very short fragments\n","            sentences.append({\n","                \"text\": s,\n","                \"title\": title,\n","                \"is_supporting\": is_supporting,\n","                \"source_paragraph\": paragraph\n","            })\n","    return sentences\n","\n","def build_bm25_sentence_context(example, k=10):\n","    \"\"\"Split all paragraphs into sentences, rank by BM25, return top-K.\"\"\"\n","    all_sentences = []\n","    for p in example[\"paragraphs\"]:\n","        all_sentences.extend(split_paragraph_to_sentences(p))\n","\n","    if not all_sentences:\n","        return \"\", [], []\n","\n","    tokenized_sents = [simple_tokenize(s[\"text\"]) for s in all_sentences]\n","    bm25 = BM25Okapi(tokenized_sents)\n","\n","    query_tokens = simple_tokenize(example[\"question\"])\n","    scores = bm25.get_scores(query_tokens)\n","\n","    ranked = sorted(\n","        zip(all_sentences, scores),\n","        key=lambda x: x[1],\n","        reverse=True\n","    )\n","\n","    topk = ranked[:k]\n","    topk_context = \"\\n\\n\".join(\n","        f\"[{s['title']}] {s['text']}\" for s, _ in topk\n","    )\n","\n","    return topk_context, topk, all_sentences\n","\n","# Test on 10 examples\n","sample = load_musique_jsonl(DEV_FILE, max_examples=10)\n","\n","for K in [5, 10, 15]:\n","    print(f\"\\n{'='*80}\")\n","    print(f\"K = {K}\")\n","    print(f\"{'='*80}\")\n","\n","    for i, ex in enumerate(sample, start=1):\n","        ctx, topk, all_sents = build_bm25_sentence_context(ex, k=K)\n","\n","        # Count how many top-K sentences come from supporting paragraphs\n","        gold_sents = [s for s in all_sents if s[\"is_supporting\"]]\n","        retrieved_supporting = sum(1 for s, _ in topk if s[\"is_supporting\"])\n","\n","        print(f\"\\nEx {i}: {ex['question'][:80]}...\")\n","        print(f\"  Total sentences: {len(all_sents)} | \"\n","              f\"Gold supporting sentences: {len(gold_sents)} | \"\n","              f\"Retrieved from supporting: {retrieved_supporting}/{K}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bCiWiQYY9FXE","executionInfo":{"status":"ok","timestamp":1776018550117,"user_tz":300,"elapsed":95,"user":{"displayName":"Siddhi Dabholkar","userId":"11668982913240243302"}},"outputId":"3a68414b-93a2-43dc-c452-7c413d199e34"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","================================================================================\n","K = 5\n","================================================================================\n","\n","Ex 1: Where do Greyhound buses leave from in the city where Arna Selznick's employer i...\n","  Total sentences: 100 | Gold supporting sentences: 11 | Retrieved from supporting: 2/5\n","\n","Ex 2: Which county does Lloyd Dane's birthplace belong to?...\n","  Total sentences: 67 | Gold supporting sentences: 5 | Retrieved from supporting: 1/5\n","\n","Ex 3: Who wrote \"Turn Me On\" by performer of \"Happy Pills\"?...\n","  Total sentences: 84 | Gold supporting sentences: 7 | Retrieved from supporting: 3/5\n","\n","Ex 4: Who did the screenwriter for Good Will Hunting play in Dazed and Confused?...\n","  Total sentences: 75 | Gold supporting sentences: 9 | Retrieved from supporting: 1/5\n"