    # Try to find the LAST \"Answer:\" in the ))\n","    if matches:\n","        return matches[-1].group(1).strip().rstrip(\".\")\n","\n","    # Try \"So, the final answer is...\" pattern (Flan-T5 loves this)output (model may repeat it)\n","    matches = list(re.finditer(r\"(?:Final\\s+)?Answer:\\s*(.*)\", output, re.IGNORECASE\n","    match = re.search(r\"(?:so,?\\s+)?the\\s+(?:final\\s+)?answer\\s+is\\s+(.*)\", output, re.IGNORECASE)\n","    if match:\n","        return match.group(1).strip().rstrip(\".\")\n","\n","    # Fallback: first sentence only (better than last line for Flan-T5)\n","    first_sent = re.split(r'[.\\n]', output.strip())[0].strip()\n","    return first_sent if first_sent else output.strip()\n","\n","sample = load_musique_jsonl(DEV_FILE, max_examples=10)\n","\n","for i, ex in enumerate(sample, start=1):\n","    question = ex[\"question\"]\n","    gold = ex[\"answer\"]\n","    context = build_supporting_paragraphs_context(ex)\n","    prompt = build_cot_prompt_v3(question, context)\n","\n","    inputs = tokenizer(\n","        prompt,\n","        return_tensors=\"pt\",\n","        truncation=True,\n","        max_length=4096\n","    ).to(device)\n","\n","    with torch.no_grad():\n","        outputs = model.generate(\n","            **inputs,\n","            max_new_tokens=256,\n","            num_beams=4,\n","            no_repeat_ngram_size=3,\n","            early_stopping=True\n","        )\n","\n","    raw_output = tokenizer.decode(outputs[0], skip_special_tokens=True)\n","    pred = extract_answer_v3(raw_output)\n","\n","    print(f\"\\n{'='*80}\")\n","    print(f\"Example {i}\")\n","    print(f\"Question: {question}\")\n","    print(f\"Gold: {gold}\")\n","    print(f\"Raw output: {raw_output}\")\n","    print(f\"Extracted: {pred}\")\n","    print(f\"EM: {compute_em_with_aliases(pred, ex)} | F1: {compute_f1_with_aliases(pred, ex):.3f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qUdMTSWSt-dF","executionInfo":{"statu