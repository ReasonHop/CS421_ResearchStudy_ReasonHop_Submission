    question = ex[\"question\"]\n","    paragraphs = ex[\"paragraphs\"]\n","    para_texts = [paragraph_to_text(p) for p in paragraphs]\n","\n","    tokenized_corpus = [simple_tokenize(t) for t in para_texts]\n","    bm25 = BM25Okapi(tokenized_corpus)\n","\n","    all_retrieved_indices = set()\n","    bridge_answers = []\n","    hop_details = []\n","\n","    for hop in range(max_hops):\n","        # Build query: original question + any bridge answers so far\n","        if hop == 0:\n","            query = question\n","        else:\n","            # Combine original question with bridge entities\n","            query = question + \" \" + \" \".join(bridge_answers)\n","\n","        query_tokens = simple_tokenize(query)\n","        scores = bm25.get_scores(query_tokens)\n","\n","        # Rank and pick top-k not already retrieved\n","        ranked = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)\n","        new_indices = []\n","        for idx in ranked:\n","            if idx not in all_retrieved_indices:\n","                new_indices.append(idx)\n","                if len(new_indices) >= k_per_hop:\n","                    break\n","\n","        all_retrieved_indices.update(new_indices)\n","\n","        # Build context from everything retrieved so far\n","        current_context = \"\\n\\n\".join(para_texts[idx] for idx in sorted(all_retrieved_indices))\n","\n","        # Get intermediate answer\n","        intermediate_prompt = build_qa_prompt(question, current_context)\n","        intermediate_answer = run_model(intermediate_prompt)\n","\n","        bridge_answers.append(intermediate_answer)\n","\n","        hop_details.append({\n","            \"hop\": hop + 1,\n","            \"query\": query[:80],\n","            \"new_paras\": len(new_indices),\n","            \"total_paras\": len(all_retrieved_indices),\n","            \"intermediate_answer\": intermediate_answer,\n","        })\n","\n","        # Early stop if answer is stable (same as previous hop)\n","        if hop > 0 and intermediate_answer == bridge_answers[-2]:\n","            break\n","\n","    # Final answer using CoT on all retrieved context\n","    final_context = \"\\n\\n\".join(para_texts[idx] for idx in sorted(all_retrieved_indices))\n","    raw = run_model(build_cot_prompt_v3(question, final_context), max_tokens=256)\n","    final_pred = extract_answer_v3(raw)\n","\n","    # Retrieval recall\n","    supporting_retrieved = sum(\n","        1 for idx in all_retrieved_indices if paragraphs[idx][\"is_supporting\"]\n","    )\n","    total_supporting = sum(p[\"is_supporting\"] for p in paragraphs)\n","\n","    return {\n","        \"final_pred\": final_pred,\n","        \"direct_pred\": bridge_answers[-1],\n","        \"hops\": hop_details,\n","        \"supporting_retrieved\": supporting_retrieved,\n","        \"total_supporting\": total_supporting,\n","        \"total_retrieved\": len(all_retrieved_indices),\n","    }\n","\n","# Test on 10 examples\n","for i, ex in enumerate(sample, start=1):\n","    result = iterative_retrieve_and_answer(ex)\n","    hop = get_hop(ex)\n","\n","    em_cot = compute_em_with_aliases(result[\"final_pred\"], ex)\n","    em_direct = compute_em_with_aliases(result[\"direct_pred\"], ex)\n","\n","    print(f\"\\n{'='*80}\")\n","    print(f\"Example {i} ({hop}): {ex['question'][:75]}\")\n","    print(f\"Gold: {ex['answer']}\")\n","\n","    for h in result[\"hops\"]:\n","        print(f\"  Hop {h['hop']}: query=\\\"{h['query'][:50]}\\\" \"\n","              f\"| +{h['new_paras']} paras (total {h['total_paras']}) \"\n","              f\"| ans=\\\"{h['intermediate_answer']}\\\"\")\n","\n","    print(f\"  Retrieval: {result['supporting_retrieved']}/{result['total_supporting']} \"\n","          f\"supporting in {result['total_retrieved']} retrieved\")\n","    print(f\"  Direct answer: {result['direct_pred']:<30} EM={em_direct}\")\n","    print(f\"  CoT answer:    {result['final_pred']:<30} EM={em_cot}\")"],"metadata":{