elf.tok(input_text, max_length=self.max_input_len,\n","                         truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n","        targets = self.tok(target_text, max_length=self.max_target_len,\n","                          truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n","        labels = targets[\"input_ids\"].squeeze()\n","        labels[labels == self.tok.pad_token_id] = -100\n","        return {\n","            \"input_ids\": inputs[\"input_ids\"].squeeze(),\n","            \"attention_mask\": inputs[\"attention_mask\"].squeeze(),\n","            \"labels\": labels,\n","        }\n","\n","train_dataset_v2 = MuSiQEAnswerFirstDataset(\n","    TRAIN_FILE, tokenizer_large,\n","    max_input_len=512, max_target_len=64,  # shorter target — answer + titles is brief\n","    max_examples=5000\n",")\n","\n","# Inspect\n","inp, tgt = train_dataset_v2.examples[0]\n","print(f\"Examples: {len(train_dataset_v2)}\")\n","print(f\"Sample target: {tgt}\")\n","print()\n","\n","# LoRA\n","lora_config = LoraConfig(\n","    task_type=TaskType.SEQ_2_SEQ_LM,\n","    r=16, lora_alpha=32, lora_dropout=0.05,\n","    target_modules=[\"q\", \"v\"],\n",")\n","model_large.enable_input_require_grads()\n","peft_model_large = get_peft_model(model_large, lora_config)\n","peft_model_large.print_trainable_parameters()\n","\n","# Train\n","BATCH_SIZE = 4\n","GRAD_ACCUM_STEPS = 4\n","EPOCHS = 3\n","LR = 3e-4\n","\n","train_loader_v2 = DataLoader(train_dataset_v2, batch_size=BATCH_SIZE, shuffle=True)\n","optimizer = torch.optim.AdamW(peft_model_large.parameters(), lr=LR, weight_decay=0.01)\n","\n","total_steps = len(train_loader_v2) * EPOCHS // GRAD_ACCUM_STEPS\n","warmup_steps = total_steps // 10\n","\n","def get_lr(step):\n","    if step < warmup_steps:\n","        return max(0.01, step / warmup_steps)\n","    progress = (step - warmup_steps) / (total_steps - warmup_steps)\n","    return max(0.05, 0.5 * (1.0 + math.cos(math.pi * progress)))\n","\n","peft_model_large.train()\n","global_step = 0\n","best_loss = float(\"inf\")\n","\n","print(f\"Training — answer-first format, target_len=64\")\n","print()\n","\n","for epoch in range(EPOCHS):\n","    epoch_loss = 0\n","    epoch_steps = 0\n","    start = time.time()\n","    optimizer.zero_grad()\n","\n","    for batch_idx, batch in enumerate(train_loader_v2):\n","        input_ids = batch[\"input_ids\"].to(device)\n","        attention_mask = batch[\"attention_mask\"].to(device)\n","        labels = batch[\"labels\"].to(device)\n","\n","        outputs = peft_model_large(input_ids=input_ids, attention_mask=attention_mask, labels=labels)\n","        loss = outputs.loss / GRAD_ACCUM_STEPS\n","        loss.backward()\n","        epoch_loss += outputs.loss.item()\n","        epoch_steps += 1\n","\n","        if (batch_idx + 1) % GRAD_ACCUM_STEPS == 0:\n","            lr_scale = get_lr(global_step)\n","            for pg in optimizer.param_groups:\n","                pg[\"lr\"] = LR * lr_scale\n","            torch.nn.utils.clip_grad_norm_(peft_model_large.parameters(), 1.0)\n","            optimizer.step()\n","            optimizer.zero_grad()\n","            global_step += 1\n","\n","        if (batch_idx + 1) % 100 == 0:\n","            avg_loss = epoch_loss / epoch_steps\n","            elapsed = time.time() - start\n","            print(f\"  Epoch {epoch+1} [{batch_idx+1}/{len(train_loader_v2)}] \"\n","                  f\"loss={avg_loss:.4f} step={global_step} time={elapsed:.0f}s\")\n","\n","    avg_loss = epoch_loss / epoch_steps\n","    elapsed = time.time() - start\n","    print(f\"\\nEpoch {epoch+1}/{EPOCHS} — loss: {avg_loss:.4f} time: {elapsed:.0f}s\")\n","\n","    if avg_loss < best_loss:\n","        best_loss = avg_loss\n","        peft_model_large.save_pretrained(\"/content/drive/MyDrive/421-Project/lora_method5_v2_best\")\n","        print(f\"  Saved best model (loss={best_loss:.4f})\")\n","    print()\n","\n","print(f\"Training complete! Best loss: {best_loss: