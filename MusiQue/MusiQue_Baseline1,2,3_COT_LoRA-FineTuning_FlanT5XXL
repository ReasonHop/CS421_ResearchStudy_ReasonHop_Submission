,"total_errors = 0\n","\n","for ex in subset:\n","    q = ex[\"question\"]\n","    gold = ex[\"answer\"]\n","    hop = get_hop(ex)\n","    context = build_supporting_paragraphs_context(ex)\n","\n","    raw = run_model(build_fewshot_cot_prompt(q, context), max_tokens=256)\n","    pred = extract_answer_v3(raw)\n","\n","    em = compute_em_with_aliases(pred, ex)\n","    f1 = compute_f1_with_aliases(pred, ex)\n","\n","    if em == 1:\n","        total_correct += 1\n","        continue\n","\n","    total_errors += 1\n","\n","    # Categorize\n","    norm_pred = normalize_text(pred)\n","    norm_gold = normalize_text(gold)\n","\n","    # Category 1: Granularity mismatch (high F1, one is substring of the other)\n","    if f1 >= 0.5 and (norm_gold in norm_pred or norm_pred in norm_gold):\n","        error_categories[\"Granularity mismatch\"].append(hop)\n","\n","    # Category 2: Near-correct / alias gap (very high F1 but not exact)\n","    elif f1 >= 0.75:\n","        error_categories[\"Near-correct / alias gap\"].append(hop)\n","\n","    # Category 3: Verbosity (pred much longer than gold, gold is substring)\n","    elif len(pred) > 2 * len(gold) and norm_gold in norm_pred:\n","        error_categories[\"Verbosity / extraction\"].append(hop)\n","\n","    # Category 4: Partial overlap (some token match but not high F1)\n","    elif 0 < f1 < 0.5:\n","        error_categories[\"Partial overlap (wrong hop or entity)\"].append(hop)\n","\n","    # Category 5: Complete miss (F1 = 0)\n","    elif f1 == 0:\n","        error_categories[\"Complete miss (wrong entity or reasoning)\"].append(hop)\n","\n","    else:\n","        error_categories[\"Other\"].append(hop)\n","\n","print(f\"Total examples: {len(subset)}\")\n","print(f\"Correct (EM=1): {total_correct} ({total_correct/len(subset)*100:.1f}%)\")\n","print(f\"Errors (EM=0): {total_errors} ({total_errors/len(subset)*100:.1f}%)\")\n","print()\n","\n","print(f\"{'Category':<45} {'Count':>6} {'% of Errors':>12} {'2-hop':>7} {'3-hop':